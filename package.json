{
  "name": "combined-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm start --prefix frontend",
    "dev:backend": "npm run start --prefix backend",
    "build": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
